# Sistema de Cajero Automatico ATM

saldo = 1000.00
pin_correcto = "1234"
intentos = 3

while intentos > 0:
    pin = input("Ingrese su PIN: ")

    if pin == pin_correcto:
        print("\nAcceso concedido.")

        while True:
            print("\n===== CAJERO AUTOMATICO =====")
            print("1. Consultar saldo")
            print("2. Depositar dinero")
            print("3. Retirar dinero")
            print("4. Salir")

            opcion = input("Seleccione una opcion: ")

            if opcion == "1":
                print(f"\nSu saldo actual es: ${saldo:.2f}")

            elif opcion == "2":
                monto = float(input("\nIngrese el monto a depositar: $"))

                if monto > 0:
                    saldo += monto
                    print(f"Deposito exitoso. Nuevo saldo: ${saldo:.2f}")
                else:
                    print("El monto debe ser mayor que cero.")

            elif opcion == "3":
                monto = float(input("\nIngrese el monto a retirar: $"))

                if monto <= 0:
                    print("El monto debe ser mayor que cero.")
                elif monto > saldo:
                    print("Fondos insuficientes.")
                else:
                    saldo -= monto
                    print(f"Retiro exitoso. Nuevo saldo: ${saldo:.2f}")

            elif opcion == "4":
                print("\nGracias por usar el cajero automatico.")
                break

            else:
                print("Opcion no valida. Intente nuevamente.")

        break

    else:
        intentos -= 1
        print(f"PIN incorrecto. Intentos restantes: {intentos}")

if intentos == 0:
    print("\nTarjeta bloqueada por demasiados intentos fallidos.")

